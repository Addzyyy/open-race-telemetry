{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Telemetry": {
    "ListenPort": 20777,
    "AllCars": false
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "telemetry-ingester"
  },
  "TimescaleDb": {
    "ConnectionString": ""
  },
  "Ingester": {
    "BatchSize": 100,
    "FlushIntervalMs": 500
  }
}
