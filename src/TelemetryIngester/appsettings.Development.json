{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  },
  "Telemetry": {
    "ListenPort": 20777,
    "AllCars": false
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "telemetry-ingester"
  },
  "TimescaleDb": {
    "ConnectionString": "Host=localhost;Port=5432;Database=telemetry;Username=telemetry;Password=telemetry"
  },
  "Ingester": {
    "BatchSize": 100,
    "FlushIntervalMs": 500
  }
}
