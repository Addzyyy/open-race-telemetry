      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT\n  FLOOR(MIN(latest_sector1_time_ms) / 60000) || ':' || LPAD(FLOOR((MIN(latest_sector1_time_ms) % 60000) / 1000)::text, 2, '0') || '.' || LPAD((MIN(latest_sector1_time_ms) % 1000)::text, 3, '0') AS \"Best S1\",\n  FLOOR(MIN(latest_sector2_time_ms) / 60000) || ':' || LPAD(FLOOR((MIN(latest_sector2_time_ms) % 60000) / 1000)::text, 2, '0') || '.' || LPAD((MIN(latest_sector2_time_ms) % 1000)::text, 3, '0') AS \"Best S2\",\n  FLOOR(MIN(latest_sector3_time_ms) / 60000) || ':' || LPAD(FLOOR((MIN(latest_sector3_time_ms) % 60000) / 1000)::text, 2, '0') || '.' || LPAD((MIN(latest_sector3_time_ms) % 1000)::text, 3, '0') AS \"Best S3\",\n  FLOOR((MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms)) / 60000) || ':' || LPAD(FLOOR(((MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms)) % 60000) / 1000)::text, 2, '0') || '.' || LPAD(((MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms)) % 1000)::text, 3, '0') AS \"Theoretical\"\nFROM session_history\nWHERE session_uid='$session' AND car_index=$car_index\n  AND latest_sector1_time_ms > 0 AND latest_sector2_time_ms > 0 AND latest_sector3_time_ms > 0"
