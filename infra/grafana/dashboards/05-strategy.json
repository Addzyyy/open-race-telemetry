  "panels": [
    {
      "id": 1,
      "title": "Session Type",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0":  { "text": "Unknown",        "index": 0 },
                "1":  { "text": "P1",             "index": 1 },
                "2":  { "text": "P2",             "index": 2 },
                "3":  { "text": "P3",             "index": 3 },
                "4":  { "text": "Short Practice", "index": 4 },
                "5":  { "text": "Q1",             "index": 5 },
                "6":  { "text": "Q2",             "index": 6 },
                "7":  { "text": "Q3",             "index": 7 },
                "8":  { "text": "Short Quali",    "index": 8 },
                "9":  { "text": "OSQ",            "index": 9 },
                "10": { "text": "Race",           "index": 10 },
                "11": { "text": "Race 2",         "index": 11 },
                "12": { "text": "Race 3",         "index": 12 },
                "13": { "text": "Time Trial",     "index": 13 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT time, session_type AS \"Type\" FROM session WHERE session_uid='$session' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 2,
      "title": "Laps",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT ld.time, ld.current_lap_num || ' / ' || s.total_laps AS \"Laps\" FROM lap_data ld JOIN LATERAL (SELECT total_laps FROM session WHERE session_uid='$session' ORDER BY time DESC LIMIT 1) s ON true WHERE ld.session_uid='$session' AND ld.car_index=$car_index ORDER BY ld.time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 3,
      "title": "Best Lap",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 5, "h": 3 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "graphMode": "none",
        "textMode": "value",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [],
          "fields": "",
          "values": true
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "#A020F0" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#A020F0", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT time, FLOOR(MIN(latest_lap_time_ms) / 60000) || ':' || LPAD(FLOOR((MIN(latest_lap_time_ms) % 60000) / 1000)::text, 2, '0') || '.' || LPAD((MIN(latest_lap_time_ms) % 1000)::text, 3, '0') AS \"Best Lap\" FROM session_history WHERE session_uid='$session' AND car_index=$car_index AND latest_lap_time_ms > 0 AND $__timeFilter(time) GROUP BY time ORDER BY MIN(latest_lap_time_ms) ASC LIMIT 1"
        }
      ]
    },
    {
      "id": 4,
      "title": "Theoretical Best",
      "type": "stat",
      "gridPos": { "x": 13, "y": 0, "w": 5, "h": 3 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "graphMode": "none",
        "textMode": "value",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [],
          "fields": "",
          "values": true
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "#00FF00" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#00FF00", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT now() AS time,\n  FLOOR((MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms)) / 60000) || ':' || LPAD(FLOOR(((MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms)) % 60000) / 1000)::text, 2, '0') || '.' || LPAD(((MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms)) % 1000)::text, 3, '0') AS \"Theoretical\"\nFROM session_history\nWHERE session_uid='$session' AND car_index=$car_index\n  AND latest_sector1_time_ms > 0 AND latest_sector2_time_ms > 0 AND latest_sector3_time_ms > 0"
        }
      ]
    },
    {
      "id": 5,
      "title": "Gap to Theoretical",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT now() AS time,\n  (MIN(latest_lap_time_ms) - (MIN(latest_sector1_time_ms) + MIN(latest_sector2_time_ms) + MIN(latest_sector3_time_ms))) / 1000.0 AS \"Gap\"\nFROM session_history\nWHERE session_uid='$session' AND car_index=$car_index\n  AND latest_lap_time_ms > 0 AND latest_sector1_time_ms > 0 AND latest_sector2_time_ms > 0 AND latest_sector3_time_ms > 0"
        }
      ]
    },
    {
      "id": 6,
      "title": "Stint Table",
      "type": "table",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "footer": { "show": false, "reducer": ["sum"], "enablePagination": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Compound" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "16": { "text": "Soft",   "color": "red",       "index": 0 },
                      "17": { "text": "Medium", "color": "yellow",    "index": 1 },
                      "18": { "text": "Hard",   "color": "dark-gray", "index": 2 },
                      "7":  { "text": "Inter",  "color": "green",     "index": 3 },
                      "8":  { "text": "Wet",    "color": "blue",      "index": 4 }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH stints AS (\n  SELECT time, visual_tyre_compound, tyres_age_laps,\n    LAG(visual_tyre_compound) OVER (ORDER BY time) AS prev_compound,\n    LAG(tyres_age_laps) OVER (ORDER BY time) AS prev_age\n  FROM car_status\n  WHERE session_uid='$session' AND car_index=$car_index AND visual_tyre_compound IS NOT NULL\n),\nstint_starts AS (\n  SELECT time, visual_tyre_compound, tyres_age_laps,\n    ROW_NUMBER() OVER (ORDER BY time) AS stint_num\n  FROM stints\n  WHERE prev_compound IS NULL OR visual_tyre_compound != prev_compound OR tyres_age_laps < prev_age\n)\nSELECT stint_num AS \"Stint\",\n  visual_tyre_compound AS \"Compound\",\n  tyres_age_laps AS \"Start Age\"\nFROM stint_starts\nORDER BY stint_num"
        }
      ]
    },
    {
      "id": 7,
      "title": "Lap Time by Compound",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 11, "w": 16, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          },
          "unit": "none",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT sh.time, sh.latest_lap_time_ms / 1000.0 AS \"Lap Time\", cs.visual_tyre_compound AS \"compound\"\nFROM session_history sh\nJOIN LATERAL (\n  SELECT visual_tyre_compound FROM car_status\n  WHERE session_uid='$session' AND car_index=$car_index AND visual_tyre_compound IS NOT NULL AND time <= sh.time\n  ORDER BY time DESC LIMIT 1\n) cs ON true\nWHERE sh.session_uid='$session' AND sh.car_index=$car_index AND sh.latest_lap_time_ms > 0 AND $__timeFilter(sh.time)\nORDER BY sh.time"
        }
      ]
    },
    {
      "id": 8,
      "title": "Compound Stats",
      "type": "table",
      "gridPos": { "x": 16, "y": 11, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "footer": { "show": false, "reducer": ["sum"], "enablePagination": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Compound" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "16": { "text": "Soft",   "color": "red",       "index": 0 },
                      "17": { "text": "Medium", "color": "yellow",    "index": 1 },
                      "18": { "text": "Hard",   "color": "dark-gray", "index": 2 },
                      "7":  { "text": "Inter",  "color": "green",     "index": 3 },
                      "8":  { "text": "Wet",    "color": "blue",      "index": 4 }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH laps AS (\n  SELECT sh.latest_lap_time_ms, cs.visual_tyre_compound\n  FROM session_history sh\n  JOIN LATERAL (\n    SELECT visual_tyre_compound FROM car_status\n    WHERE session_uid='$session' AND car_index=$car_index AND visual_tyre_compound IS NOT NULL AND time <= sh.time\n    ORDER BY time DESC LIMIT 1\n  ) cs ON true\n  WHERE sh.session_uid='$session' AND sh.car_index=$car_index AND sh.latest_lap_time_ms > 0\n)\nSELECT visual_tyre_compound AS \"Compound\",\n  COUNT(*) AS \"Laps\",\n  FLOOR(MIN(latest_lap_time_ms) / 60000) || ':' || LPAD(FLOOR((MIN(latest_lap_time_ms) % 60000) / 1000)::text, 2, '0') || '.' || LPAD((MIN(latest_lap_time_ms) % 1000)::text, 3, '0') AS \"Best\",\n  FLOOR(AVG(latest_lap_time_ms)::bigint / 60000) || ':' || LPAD(FLOOR((AVG(latest_lap_time_ms)::bigint % 60000) / 1000)::text, 2, '0') || '.' || LPAD((AVG(latest_lap_time_ms)::bigint % 1000)::text, 3, '0') AS \"Avg\",\n  FLOOR(MAX(latest_lap_time_ms) / 60000) || ':' || LPAD(FLOOR((MAX(latest_lap_time_ms) % 60000) / 1000)::text, 2, '0') || '.' || LPAD((MAX(latest_lap_time_ms) % 1000)::text, 3, '0') AS \"Worst\"\nFROM laps\nGROUP BY visual_tyre_compound\nORDER BY MIN(latest_lap_time_ms) ASC"
        }
      ]
    },
    {
