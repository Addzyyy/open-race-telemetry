          "rawSql": "SELECT time, fuel_remaining_laps AS \"Est. Fuel Laps\"\nFROM car_status\nWHERE session_uid='$session' AND car_index=$car_index AND fuel_remaining_laps IS NOT NULL AND $__timeFilter(time)\nORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 11,
      "title": "Pit Stop History",
      "type": "table",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 7 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "footer": { "show": false, "reducer": ["sum"], "enablePagination": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Compound" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "16": { "text": "Soft",   "color": "red",       "index": 0 },
                      "17": { "text": "Medium", "color": "yellow",    "index": 1 },
                      "18": { "text": "Hard",   "color": "dark-gray", "index": 2 },
                      "7":  { "text": "Inter",  "color": "green",     "index": 3 },
                      "8":  { "text": "Wet",    "color": "blue",      "index": 4 }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT DISTINCT ON (ld.num_pit_stops)\n  ld.time,\n  ld.num_pit_stops AS \"Pit #\",\n  ld.current_lap_num AS \"Lap\",\n  cs.visual_tyre_compound AS \"Compound\"\nFROM lap_data ld\nJOIN LATERAL (\n  SELECT visual_tyre_compound FROM car_status\n  WHERE session_uid='$session' AND car_index=$car_index AND visual_tyre_compound IS NOT NULL AND time >= ld.time\n  ORDER BY time ASC LIMIT 1\n) cs ON true\nWHERE ld.session_uid='$session' AND ld.car_index=$car_index AND ld.pit_status > 0\nORDER BY ld.num_pit_stops, ld.time ASC"
        }
      ]
    },
    {
      "id": 12,
      "title": "Best Sectors",
      "type": "table",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "footer": { "show": false, "reducer": ["sum"], "enablePagination": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [],
          "thresholds": {
