    {
      "id": 2,
      "title": "Best Lap per Session",
      "type": "xychart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH session_bests AS (\n  SELECT s.session_uid, MAX(s.time) AS session_time,\n    MIN(sh.latest_lap_time_ms) FILTER (WHERE sh.latest_lap_time_ms > 0) / 1000.0 AS best_lap\n  FROM session s\n  JOIN session_history sh ON sh.session_uid = s.session_uid AND sh.car_index = $car_index\n  GROUP BY s.session_uid\n  ORDER BY session_time ASC\n)\nSELECT ROW_NUMBER() OVER (ORDER BY session_time) AS \"Session #\", best_lap AS \"Best Lap (s)\"\nFROM session_bests"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#A020F0" },
          "unit": "s",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Consistency Over Sessions",
      "type": "xychart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH session_stats AS (\n  SELECT s.session_uid, MAX(s.time) AS session_time,\n    STDDEV(sh.latest_lap_time_ms) FILTER (WHERE sh.latest_lap_time_ms > 0 AND sh.latest_lap_valid = true) / 1000.0 AS std_dev\n  FROM session s\n  JOIN session_history sh ON sh.session_uid = s.session_uid AND sh.car_index = $car_index\n  GROUP BY s.session_uid\n  ORDER BY session_time ASC\n)\nSELECT ROW_NUMBER() OVER (ORDER BY session_time) AS \"Session #\", std_dev AS \"Consistency (s)\"\nFROM session_stats"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#FFD700" },
          "unit": "s",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Best Sector Times per Session",
      "type": "xychart",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH session_sectors AS (\n  SELECT s.session_uid, MAX(s.time) AS session_time,\n    MIN(sh.latest_sector1_time_ms) FILTER (WHERE sh.latest_sector1_time_ms > 0) / 1000.0 AS best_s1,\n    MIN(sh.latest_sector2_time_ms) FILTER (WHERE sh.latest_sector2_time_ms > 0) / 1000.0 AS best_s2,\n    MIN(sh.latest_sector3_time_ms) FILTER (WHERE sh.latest_sector3_time_ms > 0) / 1000.0 AS best_s3\n  FROM session s\n  JOIN session_history sh ON sh.session_uid = s.session_uid AND sh.car_index = $car_index\n  GROUP BY s.session_uid\n  ORDER BY session_time ASC\n)\nSELECT ROW_NUMBER() OVER (ORDER BY session_time) AS \"Session #\",\n  best_s1 AS \"Best S1\", best_s2 AS \"Best S2\", best_s3 AS \"Best S3\"\nFROM session_sectors"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Best S1" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF4444" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Best S2" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#44FF44" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Best S3" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4488FF" } }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Clean Lap Rate per Session",
      "type": "xychart",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH session_clean AS (\n  SELECT s.session_uid, MAX(s.time) AS session_time,\n    ROUND(100.0 * COUNT(*) FILTER (WHERE sh.latest_lap_valid = true) / NULLIF(COUNT(*), 0), 1) AS clean_pct\n  FROM session s\n  JOIN session_history sh ON sh.session_uid = s.session_uid AND sh.car_index = $car_index AND sh.latest_lap_time_ms > 0\n  GROUP BY s.session_uid\n  ORDER BY session_time ASC\n)\nSELECT ROW_NUMBER() OVER (ORDER BY session_time) AS \"Session #\", clean_pct AS \"Clean Lap %\"\nFROM session_clean"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00FF00" },
          "unit": "percent",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Theoretical Best per Session",
      "type": "xychart",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH session_theo AS (\n  SELECT s.session_uid, MAX(s.time) AS session_time,\n    (MIN(sh.latest_sector1_time_ms) FILTER (WHERE sh.latest_sector1_time_ms > 0)\n     + MIN(sh.latest_sector2_time_ms) FILTER (WHERE sh.latest_sector2_time_ms > 0)\n     + MIN(sh.latest_sector3_time_ms) FILTER (WHERE sh.latest_sector3_time_ms > 0)) / 1000.0 AS theoretical\n  FROM session s\n  JOIN session_history sh ON sh.session_uid = s.session_uid AND sh.car_index = $car_index\n  GROUP BY s.session_uid\n  ORDER BY session_time ASC\n)\nSELECT ROW_NUMBER() OVER (ORDER BY session_time) AS \"Session #\", theoretical AS \"Theoretical Best (s)\"\nFROM session_theo"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00FF00" },
          "unit": "s",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Speed Trace — Session A vs B",
      "type": "xychart",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH best_lap AS (\n  SELECT ROW_NUMBER() OVER (ORDER BY time ASC) AS lap_num, latest_lap_time_ms\n  FROM session_history\n  WHERE session_uid='$session' AND car_index=$car_index AND latest_lap_time_ms > 0\n  ORDER BY latest_lap_time_ms ASC\n  LIMIT 1\n)\nSELECT ld.lap_distance AS \"Distance\", ct.speed AS \"Session A Speed\"\nFROM car_telemetry ct\nJOIN lap_data ld ON ld.session_uid = ct.session_uid AND ld.car_index = ct.car_index AND ld.frame_id = ct.frame_id\nWHERE ct.session_uid='$session' AND ct.car_index=$car_index\n  AND ld.current_lap_num = (SELECT lap_num FROM best_lap)\n  AND ld.lap_distance >= 0\nORDER BY ld.lap_distance"
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH best_lap AS (\n  SELECT ROW_NUMBER() OVER (ORDER BY time ASC) AS lap_num, latest_lap_time_ms\n  FROM session_history\n  WHERE session_uid='$compare_session' AND car_index=$car_index AND latest_lap_time_ms > 0\n  ORDER BY latest_lap_time_ms ASC\n  LIMIT 1\n)\nSELECT ld.lap_distance AS \"Distance\", ct.speed AS \"Session B Speed\"\nFROM car_telemetry ct\nJOIN lap_data ld ON ld.session_uid = ct.session_uid AND ld.car_index = ct.car_index AND ld.frame_id = ct.frame_id\nWHERE ct.session_uid='$compare_session' AND ct.car_index=$car_index\n  AND ld.current_lap_num = (SELECT lap_num FROM best_lap)\n  AND ld.lap_distance >= 0\nORDER BY ld.lap_distance"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisLabel": "Speed (km/h)"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Session A Speed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4488FF" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Session B Speed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF8800" } }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 42, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT now() AS time, COUNT(DISTINCT session_uid) AS \"Total Sessions\" FROM session"
        }
      ],
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    }
  ]
}
