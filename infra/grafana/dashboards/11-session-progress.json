  "panels": [
    {
      "id": 1,
      "title": "Session List",
      "type": "table",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT s.session_uid AS \"Session\",\n  MAX(s.time) AS \"Date\",\n  MAX(s.track) AS \"Track\",\n  MAX(s.session_type) AS \"Type\",\n  MAX(sh.num_laps) - 1 AS \"Laps\",\n  MIN(sh.latest_lap_time_ms) FILTER (WHERE sh.latest_lap_time_ms > 0) / 1000.0 AS \"Best Lap\",\n  AVG(sh.latest_lap_time_ms) FILTER (WHERE sh.latest_lap_time_ms > 0 AND sh.latest_lap_valid = true) / 1000.0 AS \"Avg Lap\",\n  STDDEV(sh.latest_lap_time_ms) FILTER (WHERE sh.latest_lap_time_ms > 0 AND sh.latest_lap_valid = true) / 1000.0 AS \"Std Dev\"\nFROM session s\nJOIN session_history sh ON sh.session_uid = s.session_uid AND sh.car_index = $car_index\nGROUP BY s.session_uid\nORDER BY MAX(s.time) DESC\nLIMIT 50"
        }
      ],
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
