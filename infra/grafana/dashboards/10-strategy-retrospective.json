          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT now() AS time, grid_position - position AS \"Positions Gained\"\nFROM final_classification\nWHERE session_uid='$session' AND car_index=$car_index\nLIMIT 1"
        }
      ],
      "options": {
