  "panels": [
    {
      "id": 1,
      "title": "Position vs Lap",
      "type": "xychart",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 10 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT DISTINCT ON (current_lap_num) current_lap_num AS \"Lap\", car_position AS \"Position\"\nFROM lap_data\nWHERE session_uid='$session' AND car_index=$car_index AND current_lap_num > 0\nORDER BY current_lap_num, time DESC"
        }
      ],
      "options": {
        "seriesMapping": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#FFD700" },
          "custom": {
            "axisLabel": "Position"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Position" },
            "properties": [
              { "id": "min", "value": 1 },
              { "id": "max", "value": 20 }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Final Result",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT now() AS time, position AS \"Finish Pos\"\nFROM final_classification\nWHERE session_uid='$session' AND car_index=$car_index\nLIMIT 1"
        }
      ],
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto",
        "reduceOptions": {
