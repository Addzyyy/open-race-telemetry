          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Grid vs Finish",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 5 },
