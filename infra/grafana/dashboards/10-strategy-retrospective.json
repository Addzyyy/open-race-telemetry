          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT now() AS time, penalties_time AS \"Penalties (s)\"\nFROM final_classification\nWHERE session_uid='$session' AND car_index=$car_index\nLIMIT 1"
        }
      ],
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto",
        "reduceOptions": {
