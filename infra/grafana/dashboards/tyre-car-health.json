      "title": "Tyre Compound",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT actual_tyre_compound FROM car_status WHERE session_uid = '$session_uid' AND car_index = $car_index AND actual_tyre_compound IS NOT NULL AND $__timeFilter(time) ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "16": { "text": "Soft", "color": "red" },
                "17": { "text": "Medium", "color": "yellow" },
                "18": { "text": "Hard", "color": "white" },
                "7": { "text": "Inter", "color": "green" },
                "8": { "text": "Wet", "color": "blue" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {}
