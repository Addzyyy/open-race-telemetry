      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT time, ers_harvested_lap_mguk AS \"Harvested MGU-K\", ers_harvested_lap_mguh AS \"Harvested MGU-H\", ers_deployed_lap AS \"Deployed\" FROM car_status WHERE session_uid = '$session_uid' AND car_index = $car_index AND ers_deployed_lap IS NOT NULL AND $__timeFilter(time) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "joule"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Deployed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Harvested MGU-K" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Harvested MGU-H" },
