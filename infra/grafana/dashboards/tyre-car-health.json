      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT time, ers_store_energy FROM car_status WHERE session_uid = '$session_uid' AND car_index = $car_index AND ers_store_energy IS NOT NULL AND $__timeFilter(time) ORDER BY time",
