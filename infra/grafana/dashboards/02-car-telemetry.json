          "rawQuery": true,
          "rawSql": "SELECT time, latest_lap_time_ms AS \"Last Lap\" FROM session_history WHERE session_uid = '$session' AND car_index = $car_index AND $__timeFilter(time) AND latest_lap_time_ms IS NOT NULL ORDER BY time DESC LIMIT 1",
          "refId": "A"
