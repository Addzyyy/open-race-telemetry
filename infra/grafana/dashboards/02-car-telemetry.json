    {
      "id": 8,
      "title": "Delta to Best",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT sh.time, (ld.current_lap_time_ms - best.best_time) / 1000.0 AS delta FROM lap_data ld JOIN LATERAL (SELECT latest_lap_time_ms AS best_time FROM session_history WHERE session_uid = '$session' AND car_index = $car_index AND latest_lap_time_ms IS NOT NULL ORDER BY latest_lap_time_ms ASC LIMIT 1) best ON true JOIN session_history sh ON sh.session_uid = ld.session_uid AND sh.car_index = ld.car_index WHERE ld.session_uid = '$session' AND ld.car_index = $car_index AND $__timeFilter(ld.time) ORDER BY ld.time DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
