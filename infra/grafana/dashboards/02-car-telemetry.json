  "templating": {
    "list": [
      {
        "name": "session",
        "label": "Session",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "timescaledb"
        },
        "query": "SELECT session_uid FROM session GROUP BY session_uid ORDER BY MAX(time) DESC LIMIT 20",
        "refresh": 2,
        "sort": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "car_index",
        "label": "Car",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT car_index FROM car_telemetry WHERE session_uid='$session' ORDER BY car_index",
        "refresh": 2,
        "sort": 3,
        "includeAll": false,
        "multi": false
      }
    ]
  },
