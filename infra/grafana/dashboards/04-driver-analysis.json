{
  "uid": "driver-analysis-pw",
  "title": "Driver Analysis",
  "tags": ["f1", "telemetry", "pit-wall"],
  "timezone": "browser",
  "refresh": "1s",
  "liveNow": true,
  "schemaVersion": 39,
  "graphTooltip": 2,
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "editable": true,
  "links": [
    {
      "title": "Live Timing",
      "url": "/d/live-timing-pw",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Race Engineer",
      "url": "/d/car-telemetry-pw",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Tyre Health",
      "url": "/d/tyre-health-pw",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Strategy",
      "url": "/d/strategy-pw",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Debrief",
      "url": "/d/debrief-pw",
      "includeVars": true,
      "keepTime": true,
      "type": "link",
      "targetBlank": false
