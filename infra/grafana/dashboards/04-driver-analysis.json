        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT (FLOOR(latest_lap_time_ms / 500.0) * 0.5)::text || 's' AS \"Time Bucket\", COUNT(*) AS \"Count\" FROM session_history WHERE session_uid='$session' AND car_index=$car_index AND latest_lap_time_ms > 0 AND latest_lap_valid = true GROUP BY FLOOR(latest_lap_time_ms / 500.0) ORDER BY FLOOR(latest_lap_time_ms / 500.0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Sector Consistency",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
