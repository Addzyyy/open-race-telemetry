      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 'S1' AS \"Sector\", ROUND(STDDEV(latest_sector1_time_ms)::numeric / 1000.0, 3) AS \"Std Dev (s)\" FROM session_history WHERE session_uid='$session' AND car_index=$car_index AND latest_sector1_time_ms > 0 UNION ALL SELECT 'S2', ROUND(STDDEV(latest_sector2_time_ms)::numeric / 1000.0, 3) FROM session_history WHERE session_uid='$session' AND car_index=$car_index AND latest_sector2_time_ms > 0 UNION ALL SELECT 'S3', ROUND(STDDEV(latest_sector3_time_ms)::numeric / 1000.0, 3) FROM session_history WHERE session_uid='$session' AND car_index=$car_index AND latest_sector3_time_ms > 0",
          "refId": "A"
        }
      ]
    },
