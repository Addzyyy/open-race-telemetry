    {
      "id": 16,
      "title": "Tyre Compound & Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT time, visual_tyre_compound AS \"Compound\", tyres_age_laps AS \"Age\" FROM car_status WHERE session_uid='$session' AND car_index=$car_index AND visual_tyre_compound IS NOT NULL AND $__timeFilter(time) ORDER BY time DESC LIMIT 1",
          "rawQuery": true,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "16": { "text": "SOFT", "color": "red" },
                "17": { "text": "MEDIUM", "color": "yellow" },
                "18": { "text": "HARD", "color": "white" },
                "7": { "text": "INTER", "color": "green" },
                "8": { "text": "WET", "color": "blue" }
              }
            }
