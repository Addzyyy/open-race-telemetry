    {
      "id": 13,
      "title": "Surface Temp History",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT time, tyres_surface_temp_fl AS \"FL\", tyres_surface_temp_fr AS \"FR\", tyres_surface_temp_rl AS \"RL\", tyres_surface_temp_rr AS \"RR\" FROM car_telemetry WHERE session_uid='$session' AND car_index=$car_index AND $__timeFilter(time) ORDER BY time",
          "rawQuery": true,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "FL" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#4488FF" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "FR" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#00CCCC" } }
