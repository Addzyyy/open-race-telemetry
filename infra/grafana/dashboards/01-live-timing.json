      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT\n  ld.car_position AS \"Pos\",\n  p.name AS \"Driver\",\n  p.race_number AS \"#\",\n  ld.current_lap_num AS \"Lap\",\n  sh.latest_lap_time_ms / 1000.0 AS \"Last\",\n  CASE WHEN sh.best_lap_time_lap_num > 0\n    THEN (SELECT lh.latest_lap_time_ms FROM session_history lh\n          WHERE lh.session_uid = '$session' AND lh.car_index = ld.car_index\n          ORDER BY lh.latest_lap_time_ms ASC NULLS LAST LIMIT 1) / 1000.0\n    ELSE NULL END AS \"Best\",\n  sh.latest_sector1_time_ms / 1000.0 AS \"S1\",\n  sh.latest_sector2_time_ms / 1000.0 AS \"S2\",\n  sh.latest_sector3_time_ms / 1000.0 AS \"S3\",\n  cs.visual_tyre_compound AS \"Tyre\",\n  cs.tyres_age_laps AS \"Age\",\n  ld.num_pit_stops AS \"Pits\"\nFROM lap_data ld\nJOIN LATERAL (\n  SELECT name, race_number FROM participants\n  WHERE session_uid = '$session' AND car_index = ld.car_index\n  ORDER BY time DESC LIMIT 1\n) p ON true\nJOIN LATERAL (\n  SELECT latest_lap_time_ms, latest_sector1_time_ms, latest_sector2_time_ms,\n         latest_sector3_time_ms, best_lap_time_lap_num\n  FROM session_history\n  WHERE session_uid = '$session' AND car_index = ld.car_index\n  ORDER BY time DESC LIMIT 1\n) sh ON true\nJOIN LATERAL (\n  SELECT visual_tyre_compound, tyres_age_laps FROM car_status\n  WHERE session_uid = '$session' AND car_index = ld.car_index\n    AND visual_tyre_compound IS NOT NULL\n  ORDER BY time DESC LIMIT 1\n) cs ON true\nWHERE ld.session_uid = '$session'\n  AND ld.time = (SELECT MAX(time) FROM lap_data WHERE session_uid = '$session' AND car_index = ld.car_index)\nORDER BY ld.car_position ASC"
        }
      ]
    },
