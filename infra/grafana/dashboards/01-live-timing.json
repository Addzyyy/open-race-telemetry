          "rawSql": "SELECT\n  ROW_NUMBER() OVER (ORDER BY sh.time DESC) AS \"Lap\",\n  sh.latest_sector1_time_ms / 1000.0 AS \"S1\",\n  sh.latest_sector2_time_ms / 1000.0 AS \"S2\",\n  sh.latest_sector3_time_ms / 1000.0 AS \"S3\",\n  sh.latest_lap_time_ms / 1000.0 AS \"Total\",\n  sh.latest_lap_valid AS \"Valid\"\nFROM session_history sh\nWHERE sh.session_uid = '$session'\n  AND sh.car_index = $car_index\n  AND sh.latest_lap_time_ms IS NOT NULL\n  AND $__timeFilter(sh.time)\nORDER BY sh.time DESC\nLIMIT 10"
        }
      ]
