    {
      "id": 10,
      "title": "G-Ball (Best Lap)",
      "type": "xychart",
      "gridPos": { "x": 0, "y": 22, "w": 10, "h": 10 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH best_lap AS (\n  SELECT best_lap_time_lap_num\n  FROM session_history\n  WHERE session_uid='$session' AND car_index=$car_index AND best_lap_time_lap_num > 0\n  ORDER BY time DESC LIMIT 1\n)\nSELECT cm.g_force_lateral AS x, cm.g_force_longitudinal AS y\nFROM car_motion cm\nJOIN lap_data ld ON ld.session_uid = cm.session_uid AND ld.car_index = cm.car_index AND ld.frame_id = cm.frame_id\nWHERE cm.session_uid='$session' AND cm.car_index=$car_index\n  AND ld.current_lap_num = (SELECT best_lap_time_lap_num FROM best_lap)\nORDER BY cm.time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00FF00" },
          "custom": { "axisCenteredZero": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "x" },
            "properties": [
              { "id": "min", "value": -5 },
              { "id": "max", "value": 5 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "y" },
            "properties": [
              { "id": "min", "value": -5 },
              { "id": "max", "value": 5 }
            ]
          }
        ]
      },
      "options": {
        "seriesMapping": "manual",
        "series": [
          {
            "x": { "field": "x" },
            "y": { "field": "y" },
            "pointSize": { "fixed": 3 },
            "pointColor": { "fixed": "#00FF00" }
          }
        ],
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      }
    },
    {
      "id": 11,
      "title": "G-Ball (Session)",
