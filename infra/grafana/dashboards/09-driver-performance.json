            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#00FF00" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF8800" } }
            ]
          }
        ]
      },
      "options": {
        "xField": "Sector",
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "fillOpacity": 80,
        "gradientMode": "none",
        "orientation": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
