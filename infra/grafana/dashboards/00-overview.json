    {
      "id": 3,
      "title": "Lap / Total",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT ld.time, ld.current_lap_num || ' / ' || s.total_laps AS \"Lap\" FROM lap_data ld JOIN LATERAL (SELECT total_laps FROM session WHERE session_uid='$session' ORDER BY time DESC LIMIT 1) s ON true WHERE ld.session_uid='$session' AND ld.car_index=$car_index ORDER BY ld.time DESC LIMIT 1",
          "rawQuery": true,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
