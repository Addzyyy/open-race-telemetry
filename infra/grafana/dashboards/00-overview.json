    {
      "id": 8,
      "title": "Timing Tower",
      "type": "table",
      "gridPos": { "h": 11, "w": 14, "x": 0, "y": 3 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawSql": "SELECT\n  ld.car_position AS \"Pos\",\n  p.name AS \"Driver\",\n  FLOOR(sh.latest_lap_time_ms / 60000) || ':' || LPAD(FLOOR((sh.latest_lap_time_ms % 60000) / 1000)::text, 2, '0') || '.' || LPAD((sh.latest_lap_time_ms % 1000)::text, 3, '0') AS \"Last\",\n  cs.visual_tyre_compound AS \"Tyre\",\n  cs.tyres_age_laps AS \"Age\",\n  ld.num_pit_stops AS \"Pits\"\nFROM lap_data ld\nJOIN LATERAL (\n  SELECT name FROM participants\n  WHERE session_uid='$session' AND car_index=ld.car_index\n  ORDER BY time DESC LIMIT 1\n) p ON true\nJOIN LATERAL (\n  SELECT latest_lap_time_ms FROM session_history\n  WHERE session_uid='$session' AND car_index=ld.car_index\n  ORDER BY time DESC LIMIT 1\n) sh ON true\nJOIN LATERAL (\n  SELECT visual_tyre_compound, tyres_age_laps FROM car_status\n  WHERE session_uid='$session' AND car_index=ld.car_index AND visual_tyre_compound IS NOT NULL\n  ORDER BY time DESC LIMIT 1\n) cs ON true\nWHERE ld.session_uid='$session'\n  AND ld.time = (SELECT MAX(time) FROM lap_data WHERE session_uid='$session' AND car_index=ld.car_index)\nORDER BY ld.car_position ASC",
          "rawQuery": true,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Tyre" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "16": { "text": "S" },
                      "17": { "text": "M" },
                      "18": { "text": "H" },
                      "7": { "text": "I" },
                      "8": { "text": "W" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false }
      }
    },
